{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@openfable/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for the OpenFable API",
  "keywords": ["openfable", "ai", "sdk", "coding-assistant"],
  "type": "module",
  "license": "MIT",
  "author": "OpenFable Contributors",
  "homepage": "https://github.com/xanstomper/OpenFable-Code",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanstomper/OpenFable-Code.git",
    "directory": "packages/sdk/js"
  },
  "bugs": {
    "url": "https://github.com/xanstomper/OpenFable-Code/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "bun ./script/build.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./v2": "./src/v2/index.ts",
    "./v2/client": "./src/v2/client.ts",
    "./v2/gen/client": "./src/v2/gen/client/index.ts",
    "./v2/server": "./src/v2/server.ts"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@hey-api/openapi-ts": "0.90.10",
    "@tsconfig/node22": "catalog:",
    "@types/cross-spawn": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "cross-spawn": "catalog:"
  }
}
